@{
    ViewData["Title"] = "О компании";
}

@section Styles {
    <link rel="stylesheet" href="~/aboutcompany.css" asp-append-version="true" />
}

<h1>О мастерской "Мир сувениров"</h1>

<section class="about-section">
    <h2>Наша история</h2>
    <div class="story-content">
        <p>Мастерская "Мир сувениров" создана в 2015 году энтузиастами, влюбленными в искусство создания красивых вещей. Начав с небольшой мастерской по производству шкатулок, мы выросли в полноценный сувенирный центр с собственным производством.</p>
        <blockquote class="philosophy-quote">
            <p>Наша философия: каждый предмет должен нести в себе частичку души и тепла рук мастеров.</p>
        </blockquote>
    </div>
</section>

<section class="about-section">
    <h2>Почему выбирают нас</h2>
    <div class="features-grid">
        <div class="feature-item">
            <div class="feature-icon">🎁</div>
            <h3>Уникальность</h3>
            <p>Многие модели выпускаются ограниченными сериями</p>
        </div>
        <div class="feature-item">
            <div class="feature-icon">🌳</div>
            <h3>Натуральные материалы</h3>
            <p>Дерево, керамика, натуральные ткани</p>
        </div>
        <div class="feature-item">
            <div class="feature-icon">✨</div>
            <h3>Качество исполнения</h3>
            <p>Тщательная проработка деталей</p>
        </div>
        <div class="feature-item">
            <div class="feature-icon">🎨</div>
            <h3>Авторский дизайн</h3>
            <p>Собственные коллекции от наших художников</p>
        </div>
    </div>
</section>

<section class="about-section">
    <h2>Наши мастера</h2>
    <p class="masters-intro">В нашей команде работают настоящие профессионалы:</p>
    <div class="masters-list">
        <div class="master-item">
            <strong>Художники-дизайнеры</strong> - разрабатывают эскизы новых коллекций
        </div>
        <div class="master-item">
            <strong>Резчики по дереву</strong> - создают уникальные шкатулки и светильники
        </div>
        <div class="master-item">
            <strong>Керамисты</strong> - работают с глиной и создают авторские изделия
        </div>
        <div class="master-item">
            <strong>Консультанты</strong> - помогут подобрать идеальный подарок
        </div>
    </div>
</section>

<section class="contacts-section">
    <h2>Контакты</h2>
    <div class="contacts-grid">
        <div class="contact-card">
            <h3>📍 Адрес</h3>
            <p>г. Москва, ул. Ремесленная, 8<br>(м. Арбатская)</p>
        </div>
        <div class="contact-card">
            <h3>📞 Телефоны</h3>
            <p>
                <a href="tel:+78007778899">8 (800) 777-88-99</a> - бесплатный по России<br>
                <a href="tel:+74957654321">+7 (495) 765-43-21</a> - московский
            </p>
        </div>
        <div class="contact-card">
            <h3>✉️ Email</h3>
            <p>
                <a href="mailto:info@primerpochti">info@primerpochti</a> - общие вопросы<br>
                <a href="mailto:orders@primerpochti">orders@primerpochti</a> - заказы для корпоративных клиентов
            </p>
        </div>
        <div class="contact-card">
            <h3>🕒 Режим работы</h3>
            <p>
                Пн-Сб: 10:00-20:00<br>
                Вс: 11:00-18:00
            </p>
        </div>
    </div>
</section>
