@model MirSuvenirov.Models.ProductFilterViewModel

<div class="catalog-page">
<h1 class="page-title">Каталог сувениров</h1>
<p><a asp-action="AddProduct" class="btn-add-product">Добавить товар</a></p>

<form method="get" asp-action="Index" class="controls">
    <div class="filter-group">
        <label for="search">Поиск</label>
        <input id="search" class="filter-input" type="text" name="search" value="@Model.Query" placeholder="Название, описание..." />
    </div>

    <div class="filter-group">
        <label for="category">Категория</label>
        <select id="category" name="category">
            <option value="all">Все категории</option>
            @foreach (var cat in Model.Categories)
            {
                var categoryDisplayName = (cat ?? string.Empty).ToLowerInvariant() switch
                {
                    "box" => "Шкатулки",
                    "lamp" => "Светильники",
                    "pen" => "Письменные принадлежности",
                    "holder" => "Держатели и органайзеры",
                    _ => cat
                };
                <option value="@cat" selected="@(Model.Category == cat)">@categoryDisplayName</option>
            }
        </select>
    </div>

    <div class="filter-group">
        <label for="material">Материал</label>
        <select id="material" name="material">
            <option value="all">Все материалы</option>
            @foreach (var mat in Model.Materials)
            {
                <option value="@mat" selected="@(Model.Material == mat)">@mat</option>
            }
        </select>
    </div>

    <div class="filter-group">
        <label for="availability">Наличие</label>
        <select id="availability" name="availability">
            <option value="all">Все</option>
            <option value="inStock" selected="@(Model.Availability == "inStock")">В наличии</option>
            <option value="onOrder" selected="@(Model.Availability == "onOrder")">Под заказ</option>
        </select>
    </div>

    <div class="filter-group">
        <label>Цена</label>
        <div class="price-inputs">
            <input type="number" name="priceMin" placeholder="От" value="@Model.PriceMin" />
            <span class="price-dash">-</span>
            <input type="number" name="priceMax" placeholder="До" value="@Model.PriceMax" />
        </div>
    </div>

    <div class="sort-group">
        <label for="sort">Сортировка</label>
        <select id="sort" name="sort">
            <option value="">По умолчанию</option>
            <option value="price_asc" selected="@(Model.Sort == "price_asc")">Цена по возрастанию</option>
            <option value="price_desc" selected="@(Model.Sort == "price_desc")">Цена по убыванию</option>
            <option value="name_asc" selected="@(Model.Sort == "name_asc")">Название А-Я</option>
            <option value="name_desc" selected="@(Model.Sort == "name_desc")">Название Я-А</option>
        </select>
    </div>

    <button type="submit" class="filter-submit">Применить</button>
    <a asp-action="Index" class="filter-reset">Сбросить</a>
</form>

<p>Найдено товаров: <strong id="catalog-found-count">@Model.TotalCount</strong></p>

<table>
    <thead>
        <tr>
            <th>Фото</th>
            <th>Название</th>
            <th>Описание</th>
            <th>Цена</th>
            <th>Наличие</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody id="catalog-table-body">
        @foreach (var p in Model.Products)
        {
            var shortDescription = (p.Description ?? string.Empty).Length > 70
                ? (p.Description ?? string.Empty).Substring(0, 70) + "..."
                : (p.Description ?? string.Empty);
            <tr>
                <td>
                    @{
                        var imageSrc = !string.IsNullOrWhiteSpace(p.Image) &&
                                       (p.Image.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                                        p.Image.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
                            ? p.Image
                            : Url.Content("~/" + (p.Image ?? string.Empty).TrimStart('/'));
                    }
                    <img src="@imageSrc" alt="@p.Name" />
                </td>
                <td class="product-name-cell">
                    <a asp-controller="Product" asp-action="Details" asp-route-id="@p.Id">@p.Name</a>
                    <div class="badge badge-material">@p.Material</div>
                    <div class="name-actions">
                        <button type="button" class="btn-quick-view product-icon-btn" onclick="openQuickView(@p.Id)" title="Быстрый просмотр" aria-label="Быстрый просмотр">
                            <span class="quick-view-icon">👁</span>
                        </button>
                        <button type="button" class="btn-add-to-basket-icon product-icon-btn" data-id="@p.Id" title="Добавить в корзину" aria-label="Добавить в корзину">
                            <span>🛒</span>
                        </button>
                        <button type="button" class="favorite-btn product-icon-btn" data-id="@p.Id" title="Добавить в избранное" aria-label="Добавить в избранное">
                            <span class="favorite-btn-icon">♡</span>
                        </button>
                    </div>
                </td>
                <td>@shortDescription</td>
                <td><span class="price-value">@p.Price.ToString("N0") руб.</span></td>
                <td class="availability-cell">
                    @if (p.InStock)
                    {
                        <span class="badge badge-instock availability-badge">В наличии</span>
                    }
                    else
                    {
                        <span class="badge badge-onorder availability-badge">Под заказ</span>
                    }
                </td>
                <td>
                    <button type="button" class="action-btn add-cart-btn add-to-basket-btn" data-id="@p.Id">В корзину</button>
                    <button type="button" class="action-btn delete-product-btn" data-id="@p.Id" data-name="@p.Name">Удалить</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<div id="catalog-pagination" class="catalog-pagination"></div>
</div>

@section Scripts {
    <script src="~/ajax-stub.js"></script>
    <script src="~/basket.js"></script>
    <script src="~/favorites.js"></script>
    <script src="~/quick-view.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var filtersForm = document.querySelector('form.controls');
            var submitTimer = null;
            var tableBody = document.getElementById('catalog-table-body');
            var foundCount = document.getElementById('catalog-found-count');
            var pagination = document.getElementById('catalog-pagination');
            var currentPage = @Model.Page;
            var currentTotalPages = @Model.TotalPages;

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');
            }

            function normalizeImagePath(path) {
                if (!path) return '';
                var value = String(path).trim();
                if (/^https?:\/\//i.test(value) || /^data:/i.test(value)) {
                    return value;
                }
                return '/' + value.replace(/^\/+/, '');
            }

            function renderProducts(products) {
                if (!tableBody) return;

                if (!Array.isArray(products) || products.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:24px;">Товаров не найдено</td></tr>';
                    if (window.updateFavoriteButtonsGlobal) {
                        window.updateFavoriteButtonsGlobal();
                    }
                    return;
                }

                var rowsHtml = products.map(function (p) {
                    var inStockBadge = p.inStock
                        ? '<span class="badge badge-instock availability-badge">В наличии</span>'
                        : '<span class="badge badge-onorder availability-badge">Под заказ</span>';
                    var descriptionValue = String(p.description || '');
                    var shortDescription = descriptionValue.length > 70
                        ? descriptionValue.substring(0, 70) + '...'
                        : descriptionValue;

                    return '' +
                        '<tr>' +
                            '<td><img src="' + escapeHtml(normalizeImagePath(p.image)) + '" alt="' + escapeHtml(p.name) + '"></td>' +
                            '<td class="product-name-cell">' +
                                '<a href="/Product/Details/' + p.id + '">' + escapeHtml(p.name) + '</a>' +
                                '<div class="badge badge-material">' + escapeHtml(p.material) + '</div>' +
                                '<div class="name-actions">' +
                                    '<button type="button" class="btn-quick-view product-icon-btn" onclick="openQuickView(' + p.id + ')" title="Быстрый просмотр" aria-label="Быстрый просмотр"><span class="quick-view-icon">👁</span></button>' +
                                    '<button type="button" class="btn-add-to-basket-icon product-icon-btn" data-id="' + p.id + '" title="Добавить в корзину" aria-label="Добавить в корзину"><span>🛒</span></button>' +
                                    '<button type="button" class="favorite-btn product-icon-btn" data-id="' + p.id + '" title="Добавить в избранное" aria-label="Добавить в избранное"><span class="favorite-btn-icon">♡</span></button>' +
                                '</div>' +
                            '</td>' +
                            '<td>' + escapeHtml(shortDescription) + '</td>' +
                            '<td><span class="price-value">' + Number(p.price || 0).toLocaleString('ru-RU') + ' руб.</span></td>' +
                            '<td class="availability-cell">' + inStockBadge + '</td>' +
                            '<td>' +
                                '<button type="button" class="action-btn add-cart-btn add-to-basket-btn" data-id="' + p.id + '">В корзину</button>' +
                                '<button type="button" class="action-btn delete-product-btn" data-id="' + p.id + '" data-name="' + escapeHtml(p.name) + '">Удалить</button>' +
                            '</td>' +
                        '</tr>';
                }).join('');

                tableBody.innerHTML = rowsHtml;
                if (window.updateFavoriteButtonsGlobal) {
                    window.updateFavoriteButtonsGlobal();
                }
            }

            function renderPagination(totalPages, activePage) {
                if (!pagination) return;

                if (!totalPages || totalPages <= 1) {
                    pagination.innerHTML = '';
                    return;
                }

                function buildPageItems(tp, page) {
                    var items = [];
                    if (tp <= 7) {
                        for (var n = 1; n <= tp; n++) {
                            items.push(n);
                        }
                        return items;
                    }

                    var windowSize = 5;
                    var half = Math.floor(windowSize / 2);

                    items.push(1);

                    var start = page - half;
                    var end = page + half;

                    if (start < 2) {
                        end += (2 - start);
                        start = 2;
                    }

                    if (end > tp - 1) {
                        start -= (end - (tp - 1));
                        end = tp - 1;
                    }

                    start = Math.max(2, start);
                    end = Math.min(tp - 1, end);

                    if (start > 2) {
                        items.push('ellipsis');
                    }

                    for (var i = start; i <= end; i++) {
                        items.push(i);
                    }

                    if (end < tp - 1) {
                        items.push('ellipsis');
                    }

                    items.push(tp);
                    return items;
                }

                var pageItems = buildPageItems(totalPages, activePage);
                var html = '';
                html += '<button type="button" class="catalog-page-btn nav-btn" data-page="prev" ' + (activePage <= 1 ? 'disabled' : '') + '>Назад</button>';

                for (var j = 0; j < pageItems.length; j++) {
                    var item = pageItems[j];
                    if (item === 'ellipsis') {
                        html += '<span class="catalog-pagination-ellipsis">...</span>';
                        continue;
                    }

                    html += '<button type="button" class="catalog-page-btn' + (item === activePage ? ' active' : '') + '" data-page="' + item + '">' + item + '</button>';
                }

                html += '<button type="button" class="catalog-page-btn nav-btn" data-page="next" ' + (activePage >= totalPages ? 'disabled' : '') + '>Вперед</button>';
                pagination.innerHTML = html;
            }

            function applyCatalogFilters(targetPage) {
                if (!filtersForm || !window.AjaxAPI || !window.AjaxAPI.getCatalog) return;
                var requestedPage = targetPage || 1;

                var formData = new FormData(filtersForm);
                var filters = {
                    search: formData.get('search') || '',
                    category: formData.get('category') || '',
                    material: formData.get('material') || '',
                    availability: formData.get('availability') || '',
                    priceMin: formData.get('priceMin') || '',
                    priceMax: formData.get('priceMax') || '',
                    sort: formData.get('sort') || '',
                    page: requestedPage
                };

                window.AjaxAPI.getCatalog(filters)
                    .then(function (response) {
                        if (!response || !response.ok) {
                            if (window.showToast) {
                                window.showToast('Ошибка фильтрации каталога', 'error');
                            }
                            return;
                        }

                        renderProducts(response.products || []);
                        currentPage = response.page || requestedPage;
                        currentTotalPages = response.totalPages || 1;
                        if (foundCount) {
                            foundCount.textContent = (response.total || 0).toString();
                        }
                        renderPagination(currentTotalPages, currentPage);

                        var urlParams = new URLSearchParams();
                        Object.keys(filters).forEach(function (key) {
                            var value = filters[key];
                            if (key === 'page' && Number(value) <= 1) return;
                            if (!value || value === 'all') return;
                            urlParams.set(key, value);
                        });
                        var newUrl = window.location.pathname + (urlParams.toString() ? ('?' + urlParams.toString()) : '');
                        window.history.replaceState({}, '', newUrl);
                    })
                    .catch(function () {
                        if (window.showToast) {
                            window.showToast('Ошибка соединения с сервером', 'error');
                        }
                    });
            }

            function submitFiltersDebounced(delayMs, targetPage) {
                clearTimeout(submitTimer);
                submitTimer = setTimeout(function () {
                    applyCatalogFilters(targetPage || 1);
                }, delayMs || 0);
            }

            if (filtersForm) {
                filtersForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    applyCatalogFilters(1);
                });

                var immediateFields = filtersForm.querySelectorAll('select');
                immediateFields.forEach(function (field) {
                    field.addEventListener('change', function () {
                        submitFiltersDebounced(0, 1);
                    });
                });

                var typingFields = filtersForm.querySelectorAll('input[type="text"], input[type="number"]');
                typingFields.forEach(function (field) {
                    field.addEventListener('input', function () {
                        submitFiltersDebounced(450, 1);
                    });
                });
            }

            if (pagination) {
                pagination.addEventListener('click', function (e) {
                    var pageBtn = e.target.closest('.catalog-page-btn');
                    if (!pageBtn) return;

                    var pageValue = pageBtn.dataset.page;
                    var page = 0;

                    if (pageValue === 'prev') {
                        page = currentPage - 1;
                    } else if (pageValue === 'next') {
                        page = currentPage + 1;
                    } else {
                        page = parseInt(pageValue, 10);
                    }

                    if (!page || page < 1 || page > currentTotalPages || page === currentPage) return;

                    applyCatalogFilters(page);
                });
            }

            renderPagination(currentTotalPages, currentPage);

            document.addEventListener('click', function (e) {
                var basketBtn = e.target.closest('.btn-add-to-basket-icon, .add-to-basket-btn');
                if (!basketBtn) return;

                var id = parseInt(basketBtn.dataset.id, 10);
                if (window.addToBasket && id) {
                    window.addToBasket(id, basketBtn);
                }
            });

            document.addEventListener('click', function (e) {
                var deleteBtn = e.target.closest('.delete-product-btn');
                if (!deleteBtn) return;

                var id = parseInt(deleteBtn.dataset.id, 10);
                var name = deleteBtn.dataset.name || '';
                if (!id || !window.AjaxAPI || !window.AjaxAPI.deleteProduct) return;

                var confirmed = window.confirm('Удалить товар "' + name + '"?');
                if (!confirmed) return;

                deleteBtn.disabled = true;
                window.AjaxAPI.deleteProduct(id)
                    .then(function (response) {
                        if (!response || !response.ok) {
                            if (window.showToast) {
                                window.showToast((response && response.error) || 'Не удалось удалить товар', 'error');
                            }
                            deleteBtn.disabled = false;
                            return;
                        }

                        if (window.showToast) {
                            window.showToast('Товар удален из каталога', 'success');
                        }
                        applyCatalogFilters(currentPage);
                    })
                    .catch(function () {
                        if (window.showToast) {
                            window.showToast('Ошибка соединения с сервером', 'error');
                        }
                        deleteBtn.disabled = false;
                    });
            });
        });
    </script>
}